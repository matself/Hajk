{
  "name": "hajk-backend",
  "version": "4.4.0",
  "description": "Hajk Backend",
  "homepage": ".",
  "repository": {
    "type": "git",
    "url": "https://github.com/hajkmap/Hajk.git"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.11"
  },
  "type": "module",
  "exports": null,
  "scripts": {
    "start": "node --env-file=.env --experimental-transform-types dist/index.ts",
    "start:prod": "node --env-file=.env --experimental-transform-types index.ts",
    "build": "shx rm -rf dist && shx cp -r server dist",
    "dev": "nodemon --exec node --env-file=.env --ext ts --watch server --experimental-transform-types server/index.ts",
    "dev:unwatch": "node --env-file=.env --experimental-transform-types server/index.ts",
    "dev:debug": "node --env-file=.env --inspect --watch-path=./server --experimental-transform-types server/index.ts",
    "reset:db": "prisma generate && prisma db push --force-reset && prisma db seed",
    "lint": "eslint ./server",
    "lint:fix": "eslint --fix server"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@quixo3/prisma-session-store": "^3.1.19",
    "activedirectory2": "^2.2.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-openapi-validator": "^5.6.2",
    "express-session": "^1.19.0",
    "fast-xml-parser": "^5.7.1",
    "fs-extra": "^8.1.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "log4js": "^6.9.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "write-excel-file": "^3.0.8",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/activedirectory2": "^1.2.6",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.9.1",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "shx": "^0.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "author": "Jacob Wodzyński <jacob.wodzynski@halmstad.se> (https://github.com/hajkmap)"
}
