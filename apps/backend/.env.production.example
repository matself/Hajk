# *** README FIRST ***
# This is a REFERENCE template for a hardened production deployment (e.g. behind
# nginx/Apache on Ubuntu, managed by systemd or pm2). It is NOT used by build_me.sh
# and is NOT loaded automatically — apps/backend/.env.example remains the template
# copied into a fresh .env on build. Copy this file's values into the target
# server's real .env manually when provisioning a production instance, generating
# a fresh SESSION_SECRET as noted below.
#
# This file is organized into categories. Each category starts with a header, surrounded by "***".

# *** General NodeJS settings ***
# Rename per-instance, e.g. to the server's hostname.
HAJK_INSTANCE_ID=Hajk-prod-01

# Set to "development" or "production", see: https://expressjs.com/en/advanced/best-practice-performance.html#set-node_env-to-production
NODE_ENV=production

# *** HTTP SERVER SETTINGS ***
# Port that the HTTP server will listen on (nginx/Apache reverse-proxies to this)
PORT=3004

# *** Backend API versions ***
#API_VERSIONS=2,3

# Running behind nginx on the same host -> trust only the loopback interface.
# Use "true" only if you fully control every hop of X-Forwarded-For (e.g. a hardened LB).
EXPRESS_TRUST_PROXY=loopback

REQUEST_LIMIT=1000kb

# Let nginx handle gzip at the reverse-proxy layer to avoid double compression.
ENABLE_GZIP_COMPRESSION=false

# Generate with: openssl rand -hex 32   — never keep the repo's example value in production
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_32

STATIC_EXPOSER_VERSION=LATEST
EXPOSE_CLIENT=true

# Restrict /admin — set to a real AD group, or if AD isn't in use, protect the path
# at the nginx layer (basic auth / IP allowlist) and leave this commented out.
#RESTRICT_ADMIN_ACCESS_TO_AD_GROUPS=GIS_ADMIN

# Alternative to AD groups: native single-password protection for /admin. Generate
# with (run from apps/backend): npm run hash-admin-password -- "yourPassword"
# then paste the printed "salt:hash" value below.
ADMIN_PASSWORD_HASH=

# Left commented: an empty-but-present key means "unrestricted" per Hajk's docs.
# Uncomment only if you intentionally want the API explorer public.
#EXPOSE_AND_RESTRICT_STATIC_API_EXPLORER=
# NOTE: this key must be non-empty for the /admin gate to be wired up at all - that's
# also true when using ADMIN_PASSWORD_HASH instead of AD groups (the value here is
# then ignored, but the key must still be present and non-empty).
EXPOSE_AND_RESTRICT_STATIC_ADMIN=GIS_ADMIN

# *** DEVELOPER'S SETTINGS ***
BROWSER=

# *** LOGGING SETTINGS ***
# "all" is far too verbose for production — floods disk and hurts perf.
LOG_LEVEL=info

# Keep disk usage bounded: 30 days of rotated, gzipped logs.
LOG_NUM_BACKUPS=30
LOG_COMPRESS_BACKUPS=true

LOG_DEBUG_TO=console,file
LOG_ACCESS_LOG_TO=accessLog
LOG_ADMIN_EVENTS=true
LOG_DETAILED_REQUEST_LOGGER=false
#DEBUG=express:*

# *** GENERIC HAJK PROXY SETTINGS, SEE #824 ***
# Demo endpoints — comment out unless actually used in this deployment.
#PROXY_GEOSERVER=https://demo.geo-solutions.it/geoserver
#PROXY_SCB=https://geodata.scb.se/geoserver/stat

#HAJK_PROXY_ADD_X_FORWARDED_HEADERS=true
#HAJK_PROXY_ADD_X_QGIS_SERVICE_URL_HEADER=true

# *** FB SOKIGO PROXY SETTINGS ***
FB_SERVICE_ACTIVE=
FB_SERVICE_BASE_URL=
FB_SERVICE_DB=
FB_SERVICE_USER=
FB_SERVICE_PASS=

# *** FME-SERVER SETTINGS ***
#FME_SERVER_ACTIVE=true
#FME_SERVER_BASE_URL=https://fmeserver.some.domain.com
#FME_SERVER_USER=someFmeUser
#FME_SERVER_PASSWORD=aGreatFmeUserPassWord
#FME_SERVER_TOKEN=00ce08a1c85e572612518e12e47a8b73151axxxx
#FME_SERVER_SECURE=true

# *** ACTIVEDIRECTORY SETTINGS ***
AD_LOOKUP_ACTIVE=false
#AD_SKIP_LOOKUP_FOR_PATHS=/robots.txt
AD_USE_GROUPS_FROM_HEADER=false
AD_TRUSTED_PROXY_IPS=10.0.1.1,10.0.1.2
AD_TRUSTED_HEADER=X-Control-Header
AD_TRUSTED_GROUP_HEADER=X-Control-Group-Header
AD_TRUSTED_EMAIL_HEADER=X-Control-Email-Header

AD_URL=ldap://some.domain.com
AD_BASE_DN=DC=test,DC=example,DC=com
AD_USERNAME=user
AD_PASSWORD=pass

AD_CHECK_CONNECTION=true
#AD_CHECK_CONNECTION_QUERY=

AD_RECONNECT=true
#AD_CONNECTTIMEOUT=60000
#AD_IDLETIMEOUT=60000
#AD_TIMEOUT=120000

#AD_EXPOSE_USER_OBJECT=true

#AD_TLS_PATH_TO_KEY=
#AD_TLS_PATH_TO_CERT=
#AD_TLS_PATH_TO_CA=
#AD_TLS_PASSPHRASE=

# AD_OVERRIDE_USER_WITH_VALUE=someUser
# AD_OVERRIDE_USER_EMAIL_WITH_VALUE=test@email.com
# AD_OVERRIDE_USER_GROUPS_WITH_VALUE=someGroup1,someGroup2

# *** INFORMATIVE BACKEND SETTINGS ***
#INFORMATIVE_CUSTOM_UPLOAD_DIR_ABSOLUTE_PATH=/opt/www/upload
#INFORMATIVE_CUSTOM_IMAGE_EXTENSIONS=".png,.jpg,.jpeg"
#INFORMATIVE_CUSTOM_AUDIO_EXTENSIONS=".mp3,.wav,.ogg"
#INFORMATIVE_CUSTOM_VIDEO_EXTENSIONS=".mp4,.mov,.ogg"

# *** OPENAPI SETTINGS ***
OPENAPI_ENABLE_RESPONSE_VALIDATION=false

# *** ANALYTICS SETTINGS ***
#ANALYTICS_TYPE="plausible"
#ANALYTICS_OPTION_DOMAIN="hajk.example.com"
#ANALYTICS_OPTION_APIHOST="https://plausible.io"
#ANALYTICS_OPTION_TRACKLOCALHOST=false

#ANALYTICS_TYPE="matomo"
#ANALYTICS_OPTION_TRACKERURL=https://xxxxxxxxxx.matomo.cloud
#ANALYTICS_OPTION_SITEID=4
#ANALYTICS_OPTION_COOKIELESS=false

# *** FIR SETTINGS ***
# FIR_REALESTATEOWNERREPORT_URL=https://fastighetsrapport-utv.domain.se/Report/fastighetsforteckning/xlsx
# FIR_TEMP_OUTPUT_DIR=/temp/
