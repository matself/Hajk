generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./hajk.db"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model LocalAccount {
  id       String    @id @default(cuid())
  userId   String    @unique
  email    String    @unique
  password String
  fullName String
  expires  DateTime?
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  fullName     String
  strategy     AuthStrategy
  localAccount LocalAccount?
  roles        RoleOnUser[]
}

model Role {
  id                  String                @id @default(cuid())
  code                String                @unique
  title               String?
  description         String?
  systemCriticalRole  Boolean               @default(false)
  users               RoleOnUser[]
  RoleOnMap           RoleOnMap[]
  RoleOnDisplayLayer  RoleOnDisplayLayer[]
  RoleOnSearchLayer   RoleOnSearchLayer[]
  RoleOnEditingLayer  RoleOnEditingLayer[]
  RoleOnLayerInstance RoleOnLayerInstance[]
  RoleOnTool          RoleOnTool[]
  RoleOnGroup         RoleOnGroup[]
}

model RoleOnUser {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RoleOnMap {
  mapId  Int
  roleId String
  map    Map    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([mapId, roleId])
}

model RoleOnDisplayLayer {
  displayLayerId String
  roleId         String?
  displayLayer   DisplayLayer @relation(fields: [displayLayerId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([displayLayerId])
}

model RoleOnSearchLayer {
  searchLayerId String
  roleId        String?
  searchLayer   SearchLayer @relation(fields: [searchLayerId], references: [id], onDelete: Cascade)
  role          Role?       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([searchLayerId])
}

model RoleOnEditingLayer {
  editingLayerId String
  roleId         String?
  editingLayer   EditingLayer @relation(fields: [editingLayerId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([editingLayerId])
}

model RoleOnLayerInstance {
  layerInstanceId String
  roleId          String
  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  layerInstance   LayerInstance @relation(fields: [layerInstanceId], references: [id], onDelete: Cascade)

  @@id([layerInstanceId, roleId])
}

model Map {
  id                Int             @id @default(autoincrement())
  locked            Boolean         @default(false)
  name              String          @unique
  options           Json            @default("{}")
  projectionId      Int?
  createdBy         String?
  createdDate       DateTime?
  lastSavedBy       String?
  lastSavedDate     DateTime?
  projection        Projection?     @relation("MapViewProjection", fields: [projectionId], references: [id])
  projections       Projection[]    @relation("MapProjections")
  tools             ToolsOnMaps[]
  layers            LayerInstance[]
  groups            GroupsOnMaps[]
  restrictedToRoles RoleOnMap[]
  themes            Theme[]

  @@index([name])
}

/// Map theme preset for quick-access layer configurations.
model Theme {
  id            Int       @id @default(autoincrement())
  mapName       String
  title         String
  owner         String?
  description   String?
  keywords      String    @default("[]") // JSON array as string
  /// Imported JSON payload (layers, metadata, etc.)
  data          Json      @default("{}")
  createdBy     String?
  createdDate   DateTime?
  lastSavedBy   String?
  lastSavedDate DateTime?
  map           Map       @relation(fields: [mapName], references: [name], onDelete: Cascade)

  @@index([mapName])
}

/// A folder owned by a DocumentHandler Tool instance that groups documents.
model DocumentFolder {
  id            Int        @id @default(autoincrement())
  /// URL-safe slug derived from title at creation time. Immutable.
  name          String
  /// Human-readable display name.
  title         String
  toolId        Int
  createdBy     String?
  createdDate   DateTime?
  lastSavedBy   String?
  lastSavedDate DateTime?
  tool          Tool       @relation(fields: [toolId], references: [id], onDelete: Cascade)
  documents     Document[]

  @@unique([toolId, name])
}

/// A document belonging to a DocumentHandler Tool instance and folder. Content is stored as JSON.
model Document {
  id            Int            @id @default(autoincrement())
  /// URL-safe slug derived from title at creation time. Immutable.
  name          String
  /// Human-readable display name.
  title         String
  /// Chapter tree content: { chapters: [...] }
  content       Json           @default("{\"chapters\":[]}")
  toolId        Int
  folderId      Int
  createdBy     String?
  createdDate   DateTime?
  lastSavedBy   String?
  lastSavedDate DateTime?
  tool          Tool           @relation(fields: [toolId], references: [id], onDelete: Cascade)
  folder        DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  @@unique([toolId, folderId, name])
}

/// Available plugin types. Each Tool instance references one of these.
model ToolType {
  type        String  @id
  title       String
  description String?
  tools       Tool[]
}

/// A configured instance of a plugin (ToolType). Several instances of the
/// same type can exist, e.g. "Dokument Bygglov" and "Dokument Detaljplaner".
model Tool {
  id                Int              @id @default(autoincrement())
  locked            Boolean          @default(false)
  type              String
  /// Instance name, distinguishes instances of the same type
  title             String?
  options           Json             @default("{}")
  createdBy         String?
  createdDate       DateTime?
  lastSavedBy       String?
  lastSavedDate     DateTime?
  /// Soft delete - set instead of removing the row
  deletedAt         DateTime?
  toolType          ToolType         @relation(fields: [type], references: [type])
  maps              ToolsOnMaps[]
  restrictedToRoles RoleOnTool[]
  documentFolders   DocumentFolder[]
  documents         Document[]

  @@index([deletedAt])
}

model ToolsOnMaps {
  mapName String
  toolId  Int
  /// Whether the tool is enabled on the map. Inactive tools keep their row (and
  /// placement) so they can be re-enabled without losing configuration.
  active  Boolean @default(true)
  /// Determines the sort between tools within a zone
  index   Int     @default(0)
  /// Placement zone in the map UI: drawer | widgetLeft | widgetRight | controlButton. Null means unplaced (managed via admin UI).
  target  String?
  /// Allows overriding default tool options (set in Tool) on a per-map basis
  options Json    @default("{}")
  map     Map     @relation(fields: [mapName], references: [name], onDelete: Cascade)
  tool    Tool    @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@id([mapName, toolId])
}

model Projection {
  id         Int       @id @default(autoincrement())
  locked     Boolean   @default(false)
  code       String    @unique
  definition String
  extent     String    @default("[]") // JSON array as string (was Decimal[])
  units      String?
  mapView    Map[]     @relation("MapViewProjection")
  maps       Map[]     @relation("MapProjections")
  service    Service[]
}

model Group {
  id                String          @id @default(cuid())
  locked            Boolean         @default(false)
  name              String
  internalName      String?
  type              GroupType       @default(Layer)
  createdBy         String?
  createdDate       DateTime?
  lastSavedBy       String?
  lastSavedDate     DateTime?
  layers            LayerInstance[]
  maps              GroupsOnMaps[]
  restrictedToRoles RoleOnGroup[]
}

model Service {
  /// Primary key; stable reference for layers and APIs. Multiple services may share the same `url`.
  id              String         @id @default(cuid())
  metadataId      String?        @unique
  projectionId    Int?
  name            String
  locked          Boolean        @default(false)
  url             String
  version         String         @default("1.3.0")
  imageFormat     String         @default("image/png")
  type            ServiceType
  serverType      ServerType     @default(GEOSERVER)
  projection      Projection?    @relation(fields: [projectionId], references: [id])
  workspace       String?
  getMapUrl       String?
  comment         String?
  createdBy       String?
  createdDate     DateTime?
  lastSavedBy     String?
  lastSavedDate   DateTime?
  healthStatus    String?
  healthCheckedAt DateTime?
  deletedAt       DateTime?
  displayLayers   DisplayLayer[]
  searchLayers    SearchLayer[]
  editingLayers   EditingLayer[]
  metadata        Metadata?      @relation(fields: [metadataId], references: [id])

  @@index([id])
  @@index([deletedAt])
}

model Metadata {
  id           String        @id @default(cuid())
  title        String?
  description  String?
  owner        String?
  url          String?
  urlTitle     String?
  urlOpenData  String?
  attribution  String?
  created      DateTime      @default(now())
  updated      DateTime      @updatedAt
  service      Service?
  displayLayer DisplayLayer?
  searchLayer  SearchLayer?

  groupsOnMaps GroupsOnMaps[]
}

model InfoClickSettings {
  id              String        @id @default(cuid())
  layerInstanceId String?
  definition      String?
  icon            String?
  format          String        @default("application/json")
  sortProperty    String?
  sortMethod      String        @default("text") // number or text
  sortDescending  Boolean       @default(false)
  displayLayer    DisplayLayer?
}

enum SearchOutputFormat {
  GML2
  GML3
  GML32
}

/// Map visualization layer (WMS, WMTS, ARCGIS, VECTOR, etc.).
model DisplayLayer {
  id                          String               @id @default(cuid())
  serviceId                   String
  metadataId                  String?              @unique
  infoClickSettingsId         String?              @unique
  selectedLayers              String               @default("[]") // JSON array as string
  locked                      Boolean              @default(false)
  name                        String
  internalName                String?
  description                 String?
  service                     Service              @relation(fields: [serviceId], references: [id])
  metadata                    Metadata?            @relation(fields: [metadataId], references: [id])
  infoClickSettings           InfoClickSettings?   @relation(fields: [infoClickSettingsId], references: [id])
  opacity                     Float                @default(1)
  maxZoom                     Int                  @default(-1)
  minZoom                     Int                  @default(-1)
  minMaxZoomAlertOnToggleOnly Boolean              @default(false)
  tiled                       Boolean              @default(false)
  singleTile                  Boolean              @default(false)
  hidpi                       Boolean              @default(false)
  legendOptions               String?
  legendUrl                   String?
  legendIconUrl               String?
  style                       String?
  customRatio                 Int                  @default(0)
  showMetadata                Boolean              @default(false)
  infoClickActive             Boolean              @default(true)
  timeSliderVisible           Boolean              @default(false)
  timeSliderStart             String?
  timeSliderEnd               String?
  hideExpandArrow             Boolean              @default(false)
  zIndex                      Int                  @default(0)
  createdBy                   String?
  createdDate                 DateTime?
  lastSavedBy                 String?
  lastSavedDate               DateTime?
  deletedAt                   DateTime?
  restrictedToRoles           RoleOnDisplayLayer[]
  instances                   LayerInstance[]
  options                     Json                 @default("{}")

  @@index([serviceId])
  @@index([deletedAt])
}

/// Search layer configuration (independent of service type; WFS is common).
model SearchLayer {
  id                     String              @id @default(cuid())
  serviceId              String
  metadataId             String?             @unique
  selectedLayers         String              @default("[]") // JSON array as string
  locked                 Boolean             @default(false)
  name                   String
  internalName           String?
  description            String?
  service                Service             @relation(fields: [serviceId], references: [id])
  metadata               Metadata?           @relation(fields: [metadataId], references: [id])
  active                 Boolean             @default(false)
  url                    String?
  searchFields           String              @default("[]") // JSON array as string
  primaryDisplayFields   String              @default("[]") // JSON array as string
  secondaryDisplayFields String              @default("[]") // JSON array as string
  shortDisplayFields     String              @default("[]") // JSON array as string
  outputFormat           SearchOutputFormat  @default(GML3)
  geometryField          String?
  infobox                String?
  aliasDict              String?
  zIndex                 Int                 @default(0)
  createdBy              String?
  createdDate            DateTime?
  lastSavedBy            String?
  lastSavedDate          DateTime?
  deletedAt              DateTime?
  restrictedToRoles      RoleOnSearchLayer[]
  instances              LayerInstance[]
  options                Json                @default("{}")

  @@index([serviceId])
  @@index([deletedAt])
}

/// Editing layer configuration (WFST and similar).
model EditingLayer {
  id                String               @id @default(cuid())
  serviceId         String
  selectedLayers    String               @default("[]") // JSON array as string
  locked            Boolean              @default(false)
  name              String
  internalName      String?
  description       String?
  service           Service              @relation(fields: [serviceId], references: [id])
  geometryField     String?
  createdBy         String?
  createdDate       DateTime?
  lastSavedBy       String?
  lastSavedDate     DateTime?
  deletedAt         DateTime?
  restrictedToRoles RoleOnEditingLayer[]
  instances         LayerInstance[]
  options           Json                 @default("{}")

  @@index([serviceId])
  @@index([deletedAt])
}

model LayerInstance {
  id                String                @id @default(cuid())
  displayLayerId    String?
  searchLayerId     String?
  editingLayerId    String?
  mapId             Int?
  groupId           String?
  displayLayer      DisplayLayer?         @relation(fields: [displayLayerId], references: [id], onDelete: Cascade)
  searchLayer       SearchLayer?          @relation(fields: [searchLayerId], references: [id], onDelete: Cascade)
  editingLayer      EditingLayer?         @relation(fields: [editingLayerId], references: [id], onDelete: Cascade)
  map               Map?                  @relation(fields: [mapId], references: [id], onDelete: Cascade)
  group             Group?                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  usage             UseType?
  restrictedToRoles RoleOnLayerInstance[]
  infoClickActive   Boolean               @default(true)
  visibleAtStart    Boolean               @default(false)
  zIndex            Int                   @default(0)
  options           Json                  @default("{}")

  @@index([displayLayerId])
  @@index([searchLayerId])
  @@index([editingLayerId])
  @@index([mapId])
  @@index([groupId])
}

model GroupsOnMaps {
  id            String         @id @default(cuid())
  mapName       String // It relates to a map via its name
  groupId       String // It relates to a group via its ID
  map           Map            @relation(fields: [mapName], references: [name], onDelete: Cascade)
  group         Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  parentGroupId String? // This particular GroupOnMap can have a parent GroupOnMap
  parent        GroupsOnMaps?  @relation("GroupOnGroups", fields: [parentGroupId], references: [id], onDelete: Cascade) // The optional parent record
  groups        GroupsOnMaps[] @relation("GroupOnGroups") // The optional list of children records

  usage          UseType // It may be used as a background or a foreground group
  name           String // It has a title, shown to the user
  toggled        Boolean
  expanded       Boolean
  exclusiveGroup Boolean   @default(false)
  infoDocument   Boolean   @default(false)
  metadataId     String?
  metadata       Metadata? @relation(fields: [metadataId], references: [id])
  index          Int       @default(0)
  layerVisibleAtStart Boolean @default(false)
  layerInfoBox        String?

  @@index([mapName])
  @@index([groupId])
}

enum ServiceType {
  ARCGIS
  VECTOR
  WFS
  WFST
  WMS
  WMTS
}

enum ServerType {
  QGIS_SERVER
  GEOSERVER
}

enum UseType {
  BACKGROUND
  FOREGROUND
}

enum AuthStrategy {
  LOCAL
  AZURE_AD
  GITHUB
}

enum GroupType {
  Layer
  Search
}
