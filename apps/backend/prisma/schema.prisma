generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String
  expiresAt DateTime
}

model LocalAccount {
  id       String    @id @default(cuid())
  userId   String    @unique
  email    String    @unique
  password String
  fullName String
  expires  DateTime?
  user     User      @relation(fields: [userId], references: [id])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  fullName     String
  strategy     AuthStrategy
  localAccount LocalAccount?
  roles        RoleOnUser[]
}

model Role {
  id                  String                @id @default(cuid())
  code                String                @unique
  title               String?
  description         String?
  systemCriticalRole  Boolean               @default(false)
  users               RoleOnUser[]
  RoleOnMap           RoleOnMap[]
  RoleOnDisplayLayer  RoleOnDisplayLayer[]
  RoleOnSearchLayer   RoleOnSearchLayer[]
  RoleOnEditingLayer  RoleOnEditingLayer[]
  RoleOnLayerInstance RoleOnLayerInstance[]
  RoleOnTool          RoleOnTool[]
  RoleOnGroup         RoleOnGroup[]
}

model RoleOnUser {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RoleOnMap {
  mapId  Int
  roleId String
  map    Map    @relation(fields: [mapId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([mapId, roleId])
}

model RoleOnDisplayLayer {
  displayLayerId String
  roleId         String?
  displayLayer   DisplayLayer @relation(fields: [displayLayerId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([displayLayerId])
}

model RoleOnSearchLayer {
  searchLayerId String
  roleId        String?
  searchLayer   SearchLayer @relation(fields: [searchLayerId], references: [id], onDelete: Cascade)
  role          Role?       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([searchLayerId])
}

model RoleOnEditingLayer {
  editingLayerId String
  roleId         String?
  editingLayer   EditingLayer @relation(fields: [editingLayerId], references: [id], onDelete: Cascade)
  role           Role?        @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([editingLayerId])
}

model RoleOnLayerInstance {
  layerInstanceId String
  roleId          String
  role            Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  layerInstance   LayerInstance @relation(fields: [layerInstanceId], references: [id], onDelete: Cascade)

  @@id([layerInstanceId, roleId])
}

model RoleOnTool {
  toolId Int
  roleId String
  tool   Tool   @relation(fields: [toolId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([toolId, roleId])
}

model RoleOnGroup {
  groupId String
  roleId  String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role    Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([groupId, roleId])
}

model Map {
  id                Int              @id @default(autoincrement())
  locked            Boolean          @default(false)
  name              String           @unique
  options           Json             @default("{}")
  createdBy         String?
  createdDate       DateTime?        @db.Timestamptz(3) // Timestamp when created
  lastSavedBy       String?
  lastSavedDate     DateTime?        @db.Timestamptz(3) // Timestamp when last saved
  projections       Projection[]
  tools             ToolsOnMaps[]
  layers            LayerInstance[]
  groups            GroupsOnMaps[]
  restrictedToRoles RoleOnMap[]
  documentFolders   DocumentFolder[]
  documents         Document[]
}

/// A folder scoped to one map that groups documents.
model DocumentFolder {
  id            Int        @id @default(autoincrement())
  /// URL-safe slug derived from title at creation time. Immutable.
  name          String
  /// Human-readable display name.
  title         String
  mapName       String
  createdBy     String?
  createdDate   DateTime?  @db.Timestamptz(3)
  lastSavedBy   String?
  lastSavedDate DateTime?  @db.Timestamptz(3)
  map           Map        @relation(fields: [mapName], references: [name], onDelete: Cascade)
  documents     Document[]

  @@unique([mapName, name])
}

/// A document belonging to a map and folder. Content is stored as JSON.
model Document {
  id            Int            @id @default(autoincrement())
  /// URL-safe slug derived from title at creation time. Immutable.
  name          String
  /// Human-readable display name.
  title         String
  /// Chapter tree content: { chapters: [...] }
  content       Json           @default("{\"chapters\":[]}")
  mapName       String
  folderId      Int
  createdBy     String?
  createdDate   DateTime?      @db.Timestamptz(3)
  lastSavedBy   String?
  lastSavedDate DateTime?      @db.Timestamptz(3)
  map           Map            @relation(fields: [mapName], references: [name], onDelete: Cascade)
  folder        DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Restrict)

  @@unique([mapName, folderId, name])
}

model Tool {
  id                Int           @id @default(autoincrement())
  locked            Boolean       @default(false)
  type              String
  options           Json          @default("{}")
  createdBy         String?
  createdDate       DateTime?     @db.Timestamptz(3) // Timestamp when created
  lastSavedBy       String?
  lastSavedDate     DateTime?     @db.Timestamptz(3) // Timestamp when last saved
  maps              ToolsOnMaps[]
  restrictedToRoles RoleOnTool[]
}

model ToolsOnMaps {
  mapName String
  toolId  Int
  /// Determines the sort between tools within a zone
  index   Int    @default(0)
  /// Placement zone in the map UI: drawer | widgetLeft | widgetRight | controlButton
  target  String @default("drawer")
  /// Allows overriding default tool options (set in Tool) on a per-map basis
  options Json   @default("{}")
  map     Map    @relation(fields: [mapName], references: [name])
  tool    Tool   @relation(fields: [toolId], references: [id])

  @@id([mapName, toolId])
}

model Projection {
  id         Int       @id @default(autoincrement())
  locked     Boolean   @default(false)
  code       String    @unique
  definition String
  extent     Decimal[] @default([])
  units      String?
  maps       Map[]
  service    Service[]
}

model Group {
  id                String          @id @default(cuid())
  locked            Boolean         @default(false)
  name              String
  internalName      String?
  type              GroupType       @default(Layer)
  createdBy         String?
  createdDate       DateTime?       @db.Timestamptz(3) // Timestamp when created
  lastSavedBy       String?
  lastSavedDate     DateTime?       @db.Timestamptz(3) // Timestamp when last saved
  layers            LayerInstance[]
  maps              GroupsOnMaps[]
  restrictedToRoles RoleOnGroup[]
}

model Service {
  /// Primary key; stable reference for layers and APIs. Multiple services may share the same `url`.
  id              String         @id @default(cuid())
  metadataId      String?        @unique
  projectionId    Int?
  name            String
  locked          Boolean        @default(false)
  url             String
  version         String         @default("1.3.0")
  imageFormat     String         @default("image/png")
  type            ServiceType
  serverType      ServerType     @default(GEOSERVER)
  projection      Projection?    @relation(fields: [projectionId], references: [id])
  workspace       String?
  getMapUrl       String?
  comment         String?
  createdBy       String?
  createdDate     DateTime?      @db.Timestamptz(3)
  lastSavedBy     String?
  lastSavedDate   DateTime?      @db.Timestamptz(3)
  healthStatus    String?
  healthCheckedAt DateTime?      @db.Timestamptz(3)
  deletedAt       DateTime?      @db.Timestamptz(3)
  displayLayers   DisplayLayer[]
  searchLayers    SearchLayer[]
  editingLayers   EditingLayer[]
  metadata        Metadata?      @relation(fields: [metadataId], references: [id])
}

model Metadata {
  id           String        @id @default(cuid())
  title        String?
  description  String?
  owner        String?
  url          String?
  urlTitle     String?
  attribution  String?
  created      DateTime      @default(now())
  updated      DateTime      @updatedAt
  service      Service?
  displayLayer DisplayLayer?
  searchLayer  SearchLayer?
}

model InfoClickSettings {
  id              String        @id @default(cuid())
  layerInstanceId String?
  definition      String?
  icon            String?
  format          String        @default("application/json")
  sortProperty    String?
  sortMethod      String        @default("text") // number or text
  sortDescending  Boolean       @default(false)
  displayLayer    DisplayLayer?
}

enum SearchOutputFormat {
  GML2
  GML3
  GML32
}

/// Map visualization layer (WMS, WMTS, ARCGIS, VECTOR, etc.).
model DisplayLayer {
  id                          String               @id @default(cuid())
  serviceId                   String
  metadataId                  String?              @unique
  infoClickSettingsId         String?              @unique
  selectedLayers              String[]             @default([])
  locked                      Boolean              @default(false)
  name                        String
  internalName                String?
  description                 String?
  service                     Service              @relation(fields: [serviceId], references: [id])
  metadata                    Metadata?            @relation(fields: [metadataId], references: [id])
  infoClickSettings           InfoClickSettings?   @relation(fields: [infoClickSettingsId], references: [id])
  opacity                     Float                @default(1)
  maxZoom                     Int                  @default(-1)
  minZoom                     Int                  @default(-1)
  minMaxZoomAlertOnToggleOnly Boolean              @default(false)
  tiled                       Boolean              @default(false)
  singleTile                  Boolean              @default(false)
  hidpi                       Boolean              @default(false)
  legendOptions               String?
  legendUrl                   String?
  legendIconUrl               String?
  style                       String?
  customRatio                 Int                  @default(0)
  showMetadata                Boolean              @default(false)
  infoClickActive             Boolean              @default(true)
  timeSliderVisible           Boolean              @default(false)
  timeSliderStart             String?
  timeSliderEnd               String?
  hideExpandArrow             Boolean              @default(false)
  zIndex                      Int                  @default(0)
  createdBy                   String?
  createdDate                 DateTime?            @db.Timestamptz(3)
  lastSavedBy                 String?
  lastSavedDate               DateTime?            @db.Timestamptz(3)
  deletedAt                   DateTime?            @db.Timestamptz(3)
  restrictedToRoles           RoleOnDisplayLayer[]
  instances                   LayerInstance[]
  options                     Json                 @default("{}")

  @@index([serviceId])
}

/// Search layer configuration (independent of service type; WFS is common).
model SearchLayer {
  id                     String              @id @default(cuid())
  serviceId              String
  metadataId             String?             @unique
  selectedLayers         String[]            @default([])
  locked                 Boolean             @default(false)
  name                   String
  internalName           String?
  description            String?
  service                Service             @relation(fields: [serviceId], references: [id])
  metadata               Metadata?           @relation(fields: [metadataId], references: [id])
  active                 Boolean             @default(false)
  url                    String?
  searchFields           String[]            @default([])
  primaryDisplayFields   String[]            @default([])
  secondaryDisplayFields String[]            @default([])
  shortDisplayFields     String[]            @default([])
  outputFormat           SearchOutputFormat  @default(GML3)
  geometryField          String?
  infobox                String?
  aliasDict              String?
  zIndex                 Int                 @default(0)
  createdBy              String?
  createdDate            DateTime?           @db.Timestamptz(3)
  lastSavedBy            String?
  lastSavedDate          DateTime?           @db.Timestamptz(3)
  deletedAt              DateTime?           @db.Timestamptz(3)
  restrictedToRoles      RoleOnSearchLayer[]
  instances              LayerInstance[]
  options                Json                @default("{}")

  @@index([serviceId])
}

/// Editing layer configuration (WFST and similar).
model EditingLayer {
  id                String               @id @default(cuid())
  serviceId         String
  selectedLayers    String[]             @default([])
  locked            Boolean              @default(false)
  name              String
  internalName      String?
  description       String?
  service           Service              @relation(fields: [serviceId], references: [id])
  geometryField     String?
  createdBy         String?
  createdDate       DateTime?            @db.Timestamptz(3)
  lastSavedBy       String?
  lastSavedDate     DateTime?            @db.Timestamptz(3)
  deletedAt         DateTime?            @db.Timestamptz(3)
  restrictedToRoles RoleOnEditingLayer[]
  instances         LayerInstance[]
  options           Json                 @default("{}")

  @@index([serviceId])
}

model LayerInstance {
  id                String                @id @default(cuid())
  displayLayerId    String?
  searchLayerId     String?
  editingLayerId    String?
  mapId             Int?
  groupId           String?
  displayLayer      DisplayLayer?         @relation(fields: [displayLayerId], references: [id])
  searchLayer       SearchLayer?          @relation(fields: [searchLayerId], references: [id])
  editingLayer      EditingLayer?         @relation(fields: [editingLayerId], references: [id])
  map               Map?                  @relation(fields: [mapId], references: [id])
  group             Group?                @relation(fields: [groupId], references: [id])
  usage             UseType?
  restrictedToRoles RoleOnLayerInstance[]
  infoClickActive   Boolean               @default(true)
  visibleAtStart    Boolean               @default(false)
  zIndex            Int                   @default(0)
  options           Json                  @default("{}")

  @@index([displayLayerId])
  @@index([searchLayerId])
  @@index([editingLayerId])
}

model GroupsOnMaps {
  id            String         @id @default(cuid())
  mapName       String // It relates to a map via its name
  groupId       String // It relates to a group via its ID
  map           Map            @relation(fields: [mapName], references: [name])
  group         Group          @relation(fields: [groupId], references: [id])
  parentGroupId String? // This particular GroupOnMap can have a parent GroupOnMap
  parent        GroupsOnMaps?  @relation("GroupOnGroups", fields: [parentGroupId], references: [id]) // The optional parent record
  groups        GroupsOnMaps[] @relation("GroupOnGroups") // The optional list of children records

  usage    UseType // It may be used as a background or a foreground group
  name     String // It has a title, shown to the user
  toggled  Boolean
  expanded Boolean
}

enum ServiceType {
  ARCGIS
  VECTOR
  WFS
  WFST
  WMS
  WMTS
}

enum ServerType {
  QGIS_SERVER
  GEOSERVER
}

enum UseType {
  BACKGROUND
  FOREGROUND
}

enum AuthStrategy {
  LOCAL
  AZURE_AD
  GITHUB
}

enum GroupType {
  Layer
  Search
}
